{
  "name": "@img-fit/angular",
  "version": "0.1.0",
  "description": "Angular adapter for img-fit — automatic width-aware images for img-fwd.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --import tsx --test test/*.test.ts"
  },
  "devDependencies": {
    "@angular/core": "^17.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "img-fit",
    "img-fwd",
    "angular",
    "image",
    "responsive",
    "optimization"
  ],
  "author": "Danilo Riedel",
  "license": "MIT",
  "peerDependencies": {
    "@angular/core": ">=12.0.0"
  },
  "dependencies": {
    "@angular/compiler": "^17.3.12",
    "@angular/platform-browser": "^17.3.12",
    "@angular/platform-browser-dynamic": "^17.3.12",
    "img-fit": "^0.1.0",
    "jsdom": "^29.1.1",
    "reflect-metadata": "^0.2.2",
    "tsx": "^4.22.4",
    "zone.js": "^0.14.10"
  }
}
